# GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa.json
GCS_BUCKET_PDFS=smartscroll_pdfs
GCS_BUCKET_GAMEPLAY=smartscroll-gameplay
GCS_BUCKET_RENDERED=smartscroll-rendered

# Vertex AI / Gemma 4
VERTEX_GEMMA_ENDPOINT=gemma-4-26b-a4b-it-maas
VERTEX_GEMMA_LOCATION=us-central1

# Firebase Admin (base64-encoded service account JSON, or leave empty to use GCP ADC)
FIREBASE_ADMIN_CREDENTIALS_JSON=

# Firebase Web SDK (frontend — Vite reads VITE_ prefix)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Backboard (topic research agent)
BACKBOARD_KEY=

# App
DEBUG=false
LOG_LEVEL=INFO
